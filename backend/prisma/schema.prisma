generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int           @id @default(autoincrement())
  email             String        @unique
  username          String
  password          String
  fullName          String
  bio               String?
  avatarUrl         String?
  shotsRemaining    Int           @default(12)
  deletesRemaining  Int           @default(1)
  shotsResetAt      DateTime      @default(now())
  lastPostedAt      DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  
  posts             Post[]
  reactions         Reaction[]
  friendsInitiated  Friend[]      @relation("UserFriends")
  friendsReceived   Friend[]      @relation("FriendUser")
}

model Post {
  id              Int           @id @default(autoincrement())
  userId          Int
  caption         String?
  imageUrl        String
  location        String?
  latitude        Float?
  longitude       Float?
  isLate          Boolean       @default(false)
  lateMinutes     Int?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  reactions       Reaction[]
  
  @@index([userId])
  @@index([createdAt])
}

model Friend {
  id          Int           @id @default(autoincrement())
  userId      Int
  friendId    Int
  status      String        @default("pending") // pending, accepted, rejected
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  user        User          @relation("UserFriends", fields: [userId], references: [id], onDelete: Cascade)
  friend      User          @relation("FriendUser", fields: [friendId], references: [id], onDelete: Cascade)
  
  @@unique([userId, friendId])
  @@index([userId])
  @@index([friendId])
  @@index([status])
}

model Reaction {
  id          Int           @id @default(autoincrement())
  userId      Int
  postId      Int
  emoji       String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  post        Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  
  @@unique([userId, postId])
  @@index([postId])
}